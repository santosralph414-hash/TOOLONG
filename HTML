<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TOOLong.com</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <header>
    <h1>Welcome to TOOLong.com</h1>
  </header>

  <main>
    <section>
      <p>Select rental items and explore features below:</p>
      <button onclick="showCart()">View Shopping Cart</button>
      <button onclick="selectRole()">Choose Role</button>
    </section>

    <div id="cartModal" class="modal">
      <div class="modal-content">
        <span class="close" onclick="closeModal()">&times;</span>
        <h2>Your Shopping Cart</h2>
        <ul id="cartItems"></ul>
      </div>
    </div>
  </main>

  <script src="script.js"></script>
</body>
</html>
